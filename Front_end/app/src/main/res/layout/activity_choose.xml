<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/cute"
    android:padding="16dp">

    <!-- Small dog-cat logo, lifted up -->

    <!-- (Optional) Welcome text directly under the image - keeps your ID -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:text="Welcome Back Buddy!!"
        android:textColor="@color/text_primary"
        android:textSize="28sp" />


    <!-- Buttons container pinned to the bottom -->
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="395dp"
        android:layout_height="386dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <Button
            android:id="@+id/admin_manage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/rounded_edittext"
            android:backgroundTint="#7B4DCC"
            android:text="USER"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/admin_view"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/rounded_edittext"
            android:backgroundTint="#7B4DCC"
            android:text="ADMIN"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/admin_set"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/rounded_edittext"
            android:backgroundTint="#7B4DCC"
            android:text="VOLUNTEER"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />


    </LinearLayout>

</RelativeLayout>
