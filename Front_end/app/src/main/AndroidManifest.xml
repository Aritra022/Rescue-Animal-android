        <activity
            android:name=".Volunteer.Volunteer_Dashboard_activity"
            android:exported="false" />
        <activity
            android:name=".Volunteer.Volunteer_registration_activity"
            android:exported="false" />
        <activity
            android:name=".Volunteer.Volunteer_Forgot_Password_activity"
            android:exported="false" />
        <activity
            android:name=".Volunteer.Rescue_Field_Activity"
            android:exported="false" />


        <activity
            android:name=".admin.Admin_Dashboard_Activity"
            android:exported="false" />
        <activity
            android:name=".admin.Admin_Forgot_Password_Activity"
